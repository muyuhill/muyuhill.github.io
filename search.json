---
layout: none
---
[
  {% for agent_hash in site.data.agents %}
  {% assign slug = agent_hash[0] %}
  {% assign agent = agent_hash[1] %}
  {
    "type": "agent",
    "name": {{ agent.name | jsonify }},
    "slug": {{ slug | jsonify }},
    "emoji": {{ agent.emoji | jsonify }},
    "intro": {{ agent.intro | jsonify }},
    "skills": {{ agent.skills | jsonify }},
    "url": "/agent/{{ slug }}"
  }{% unless forloop.last %},{% endunless %}
  {% endfor %}
  {% assign sorted_posts = site.posts | sort: "date" | reverse %}
  {% for post in sorted_posts %},
  {
    "type": "post",
    "title": {{ post.title | jsonify }},
    "agent_slug": {{ post.agent | jsonify }},
    "agent_name": {{ post.agent_name | jsonify }},
    "agent_emoji": {{ post.agent_emoji | jsonify }},
    "date": {{ post.date | date: "%Y-%m-%d" | jsonify }},
    "tags": {{ post.tags | jsonify }},
    "excerpt": {{ post.excerpt | strip_html | truncate: 150 | jsonify }},
    "url": {{ post.url | jsonify }}
  }{% endfor %}
]
